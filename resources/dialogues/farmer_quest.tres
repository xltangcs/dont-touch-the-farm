[gd_resource type="Resource" script_class="DialogueTree" format=3 uid="uid://dpfxrq7b753ea"]

[ext_resource type="Script" path="res://scripts/dialogue_tree.gd" id="1_dialogue_tree"]
[ext_resource type="Script" path="res://scripts/dialogue_node.gd" id="2_dialogue_node"]
[ext_resource type="Script" path="res://scripts/dialogue_choice.gd" id="3_dialogue_choice"]

[sub_resource type="Resource" id="DialogueChoice_yes"]
script = ExtResource("3_dialogue_choice")
text = "好的，我去帮你找"
next_index = 1

[sub_resource type="Resource" id="DialogueChoice_no"]
script = ExtResource("3_dialogue_choice")
text = "抱歉，我现在没空"
next_index = 2

[sub_resource type="Resource" id="DialogueNode_ask"]
script = ExtResource("2_dialogue_node")
speaker = "农夫"
text = "旅行者，你能帮我找3块石头吗？"
choices = Array[ExtResource("3_dialogue_choice")]([SubResource("DialogueChoice_yes"), SubResource("DialogueChoice_no")])

[sub_resource type="Resource" id="DialogueNode_yes"]
script = ExtResource("2_dialogue_node")
speaker = "农夫"
text = "太感谢你了！这些石头对我的田地很重要。"

[sub_resource type="Resource" id="DialogueNode_no"]
script = ExtResource("2_dialogue_node")
speaker = "农夫"
text = "好吧，等你方便的时候再来找我。"

[resource]
script = ExtResource("1_dialogue_tree")
nodes = Array[ExtResource("2_dialogue_node")]([SubResource("DialogueNode_ask"), SubResource("DialogueNode_yes"), SubResource("DialogueNode_no")])
